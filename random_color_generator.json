const express = require("express");
const cors = require("cors");

const app = express();

app.use(cors());
app.use(express.json());

function generateRandomRGB() {

        const red = Math.floor(Math.random() * 256);
            const green = Math.floor(Math.random() * 256);
                const blue = Math.floor(Math.random() * 256);

                    return {
                                red,
                                        green,
                                                blue,
                                                        rgb: `rgb(${red}, ${green}, ${blue})`
                    };
}

function rgbToHex(r, g, b) {

        return (
                    "#" +
                            [r, g, b]
                                        .map(value =>
                                                        value.toString(16).padStart(2, "0")
                                                                    )
                                                                                .join("")
        );
}

app.get("/api/random-color", (req, res) => {

        const colorData = generateRandomRGB();

            const hexColor = rgbToHex(
                        colorData.red,
                                colorData.green,
                                        colorData.blue
            );

                res.json({
                            success: true,
                                    rgbColor: colorData.rgb,
                                            hexColor: hexColor,
                                                    red: colorData.red,
                                                            green: colorData.green,
                                                                    blue: colorData.blue
                });
});

app.get("/", (req, res) => {
        res.send("Random Color Generator Backend Running");
});

const PORT = 5000;

app.listen(PORT, () => {
        console.log(`Server is running on port ${PORT}`);
});



import React, { useState, useEffect } from "react";
import "./App.css";

function App() {

        const [backgroundColor, setBackgroundColor] =
                useState("rgb(255,255,255)");

                    const [hexCode, setHexCode] =
                            useState("#ffffff");

                                const [rgbCode, setRgbCode] =
                                        useState("rgb(255,255,255)");

                                            const [colorHistory, setColorHistory] =
                                                    useState([]);

                                                        const [loading, setLoading] =
                                                                useState(false);

                                                                    const generateRandomColor = async () => {

                                                                                try {

                                                                                                setLoading(true);

                                                                                                            const response = await fetch(
                                                                                                                                "http://localhost:5000/api/random-color"
                                                                                                            );

                                                                                                                        const data = await response.json();

                                                                                                                                    if (data.success) {

                                                                                                                                                        setBackgroundColor(data.rgbColor);
                                                                                                                                                                        setRgbCode(data.rgbColor);
                                                                                                                                                                                        setHexCode(data.hexColor);

                                                                                                                                                                                                        setColorHistory(previousColors => [
                                                                                                                                                                                                                                data.hexColor,
                                                                                                                                                                                                                                                    ...previousColors.slice(0, 4)
                                                                                                                                                                                                        ]);
                                                                                                                                    }

                                                                                                                                                setLoading(false);

                                                                                } catch (error) {

                                                                                                console.log("Error fetching color:", error);

                                                                                                            setLoading(false);
                                                                                }
                                                                    };

                                                                        useEffect(() => {
                                                                                    generateRandomColor();
                                                                        }, []);

                                                                            return (

                                                                                        <div
                                                                                                    className="container"
                                                                                                                style={{
                                                                                                                                    backgroundColor: backgroundColor
                                                                                                                }}
                                                                                                                        >

                                                                                                                                    <div className="card">

                                                                                                                                                    <h1>🎨 Random Color Generator</h1>

                                                                                                                                                                    <p className="description">
                                                                                                                                                                                        Generate beautiful random colors
                                                                                                                                                                                                        </p>

                                                                                                                                                                                                                        <div className="color-box">

                                                                                                                                                                                                                                            <h2>Current Color</h2>

                                                                                                                                                                                                                                                                <p>
                                                                                                                                                                                                                                                                                        <strong>RGB:</strong> {rgbCode}
                                                                                                                                                                                                                                                                                                            </p>

                                                                                                                                                                                                                                                                                                                                <p>
                                                                                                                                                                                                                                                                                                                                                        <strong>HEX:</strong> {hexCode}
                                                                                                                                                                                                                                                                                                                                                                            </p>

                                                                                                                                                                                                                                                                                                                                                                                            </div>

                                                                                                                                                                                                                                                                                                                                                                                                            <button
                                                                                                                                                                                                                                                                                                                                                                                                                                className="generate-btn"
                                                                                                                                                                                                                                                                                                                                                                                                                                                    onClick={generateRandomColor}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                    >

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    loading
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                ? "Generating..."
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            : "Generate New Color"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        }

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        </button>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        <div className="history-section">

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            <h3>Recent Colors</h3>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                <div className="history-container">

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        colorHistory.map((color, index) => (

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            <div
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                key={index}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    className="history-color"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        style={{
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    backgroundColor: color
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        }}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        >

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            <span>{color}</span>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            </div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        ))
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        }

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            </div>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            </div>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        </div>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                </div>
                                                                            );
}

export default App;



