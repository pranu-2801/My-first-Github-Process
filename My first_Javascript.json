// Variables
let name = "Pranathi";
let age = 18;

// Function to check age
function checkAge(a) {
        return (a >= 18) ? "Adult" : "Minor"; // ternary operator
}

// Function to perform arithmetic operations
function arithmeticOperations(a) {
        console.log("Original Age: " + a);
            console.log("Addition (a + 5): " + (a + 5));
                console.log("Subtraction (a - 2): " + (a - 2));
                    console.log("Multiplication (a * 2): " + (a * 2));
                        console.log("Division (a / 3): " + (a / 3));
                            console.log("Modulus (a % 5): " + (a % 5));
                                console.log("Exponent (a ** 2): " + (a ** 2));
}

// Function to greet user
function greetUser(userName, userAge) {
        let status = checkAge(userAge);
            
                console.log("Hello " + userName + "!");
                    console.log("You are " + userAge + " years old.");
                        console.log("Status: " + status);
}

// Main execution
greetUser(name, age);
arithmeticOperations(age);
}
}
